# Neon PostgreSQL connection string (pooler endpoint)
# Used by server functions only — never exposed to the browser
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_ENDPOINT-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Random 32+ char string for encrypting admin session cookies
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_PASSWORD=replace_with_random_64_char_hex_string
