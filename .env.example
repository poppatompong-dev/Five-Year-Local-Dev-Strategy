# Neon PostgreSQL connection string (pooler endpoint)
# Used by the app (Vite injects VITE_ prefixed vars)
VITE_DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_ENDPOINT-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Used by scripts (node scripts/*.js)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_ENDPOINT-pooler.REGION.aws.neon.tech/neondb?sslmode=require
